APP_NAME=Laravel
APP_ENV=local
APP_KEY=
APP_DEBUG=true
# Production: set APP_URL to the exact canonical origin (scheme + host, no trailing slash),
# e.g. APP_URL=https://tryinotech.cloud — must match what users type so the LCP image
# preload + all asset URLs stay same-origin and avoid an extra redirect hop.
APP_URL=http://localhost
APP_HTML_LANG=en-PK

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=sqlite
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=laravel
# DB_USERNAME=root
# DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

# Cron (Hostinger): * * * * * cd /path/to/tryino-ecom && php artisan schedule:run
# Handles queue worker, shipping sync, search index, image variants, WhatsApp, etc.
# See routes/console.php and docs/deploy/hostinger-ssh.md §8.

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

# Public uploads disk: "local" (dev) or "s3" (production Backblaze B2).
PUBLIC_DISK_DRIVER=local

# Backblaze B2 (S3-compatible). Required when PUBLIC_DISK_DRIVER=s3.
# Create a public bucket + Application Key in B2, then set:
# AWS_ACCESS_KEY_ID=<B2 keyID>
# AWS_SECRET_ACCESS_KEY=<B2 applicationKey>
# AWS_DEFAULT_REGION=us-west-004
# AWS_BUCKET=tryino-ecom-public
# AWS_ENDPOINT=https://s3.us-west-004.backblazeb2.com
# AWS_USE_PATH_STYLE_ENDPOINT=true
# AWS_URL=https://cdn.tryinotech.cloud
#   ^ Use Cloudflare CDN URL (recommended) or the B2 S3 endpoint for AWS_URL.
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_ENDPOINT=
AWS_URL=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"

# WhatsApp (Cloud API + optional HTTP bridge for dev)
WHATSAPP_CLOUD_ENABLED=false
WHATSAPP_CLOUD_TOKEN=
WHATSAPP_CLOUD_PHONE_NUMBER_ID=
# Required for whatsapp:sync-templates — Meta → WhatsApp → API Setup → WhatsApp Business Account ID
WHATSAPP_CLOUD_WABA_ID=
WHATSAPP_CLOUD_API_VERSION=v21.0
# Meta Graph HTTP: leave empty (native on CLI when allow_url_fopen, curl on web). Use native on Hostinger SSH.
WHATSAPP_HTTP_HANDLER=
# Only set true if you must use libcurl in artisan (not recommended on shared hosting).
WHATSAPP_HTTP_CURL_IN_CLI=false
WHATSAPP_TEMPLATE_LANGUAGE=en_US
# Optional overrides when DB cloud_template_name is empty (defaults to {key}_v2 in admin templates).
WHATSAPP_TEMPLATE_ORDER_PLACED=order_placed_v2
WHATSAPP_TEMPLATE_PAYMENT_RECEIVED=
WHATSAPP_TEMPLATE_ORDER_PACKED=
WHATSAPP_TEMPLATE_ORDER_SHIPPED=
WHATSAPP_TEMPLATE_ORDER_DELIVERED=
WHATSAPP_TEMPLATE_ORDER_CANCELED=
WHATSAPP_BRIDGE_ENABLED=true
WHATSAPP_API_TOKEN=
WHATSAPP_API_URL=
WHATSAPP_FROM_NUMBER=
WHATSAPP_SEND_TRIES=5
WHATSAPP_SEND_BACKOFF=60
WHATSAPP_SEND_TIMEOUT=30
# WHATSAPP_QUEUE=default

# Bargaining assistant (deterministic pricing + optional AI polish)
BARGAIN_ENABLED=true
BARGAIN_SESSION_TTL_MINUTES=30
BARGAIN_LOCK_TTL_MINUTES=60
BARGAIN_MIN_STEP_PKR=100

# In-range nudge: bump stated offers slightly toward list when still policy-compliant.
BARGAIN_IN_RANGE_NUDGE_ENABLED=true
BARGAIN_IN_RANGE_NUDGE_MIN_STEP_PKR=100
BARGAIN_IN_RANGE_NUDGE_MAX_FRACTION=0.4
BARGAIN_AI_ENABLED=false
BARGAIN_AI_BASE_URL=https://api.openai.com/v1
# Or set OPENAI_API_KEY if you already use it app-wide.
BARGAIN_AI_API_KEY=
BARGAIN_AI_MODEL=gpt-4o-mini
# Requires active billing/credits at platform.openai.com — otherwise chat stays on draft templates (HTTP 429).
# Windows SSL issues: BARGAIN_AI_HTTP_VERIFY=false (dev only)
# php artisan bargain:test-polisher — verify key + quota from CLI

# Storefront SEO: set APP_URL to your public site URL (used for canonicals, OG URLs, sitemap, robots).
# APP_HTML_LANG=en-PK
# STORE_BUSINESS_ADDRESS="Your street, City"
# STORE_BUSINESS_CITY=Lahore
# STORE_CONTACT_EMAIL=info@example.com
# STORE_OPENING_HOURS="Mo-Sa 10:00-19:00"
# GA4 / Meta / TikTok IDs are configured in Admin → Marketing (stored in database).

# Safepay (https://getsafepay.com) — primary online payment gateway.
# Get keys from Dashboard → Developers → API Keys. Webhook secret from Developers → Endpoints.
SAFEPAY_ENABLED=true
SAFEPAY_ENVIRONMENT=sandbox
SAFEPAY_API_KEY=
SAFEPAY_MERCHANT_API_KEY=
SAFEPAY_WEBHOOK_SECRET=
SAFEPAY_INTENT=CYBERSOURCE
SAFEPAY_CURRENCY=PKR
SAFEPAY_INCLUDE_FEES=false

# Legacy wallet gateways are disabled by default in favour of Safepay.
# Flip to true and configure credentials if you want to re-enable them.
EASYPAISA_ENABLED=false
JAZZCASH_ENABLED=false

# Shipping / courier integrations
SHIPPING_SANDBOX=false
SHIPPING_WEBHOOK_SECRET=

# Courier API base URLs
LEOPARDS_API_BASE=https://api.leopardscourier.com.pk/api/v1
MP_API_BASE=https://api.mulphilogistics.com
POSTEX_API_BASE=https://api.postex.pk
RUN_COURIER_API_BASE=https://portal.runcourier.com
TCS_API_BASE=https://api.tcscourier.com

# Trax (Sonic)
TRAX_API_BASE_TESTING=https://app.sonic.pk
TRAX_API_BASE_LIVE=https://sonic.pk

# Sentry error & performance monitoring. Leave DSN empty to disable.
SENTRY_LARAVEL_DSN=
# Send error-level Laravel logs to Sentry on web requests (requires DSN). Disabled on artisan CLI automatically.
SENTRY_ENABLE_LOGS=true
SENTRY_LOG_LEVEL=error
LOG_STACK=single,sentry_logs

# GitHub deploy webhook (pull production branch after CI push). Generate secret: openssl rand -hex 32
DEPLOY_WEBHOOK_ENABLED=false
DEPLOY_WEBHOOK_SECRET=
DEPLOY_BRANCH=production

# Email when Hostinger deploy finishes (uses MAIL_*). Comma-separated for multiple.
DEPLOY_NOTIFY_ENABLED=false
DEPLOY_NOTIFY_EMAIL=tryinotech@gmail.com

# Storefront search (MySQL FULLTEXT; min token length often 3 on shared hosting)
STORE_SEARCH_QUERY_MAX_LENGTH=120
STORE_SEARCH_SUGGEST_MIN_LENGTH=2
STORE_SEARCH_SUGGEST_DEBOUNCE_MS=300
STORE_SEARCH_SUGGEST_CACHE_TTL=120
STORE_SEARCH_LOG_QUERIES=false
