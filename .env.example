APP_NAME=Laravel
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=sqlite
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=laravel
# DB_USERNAME=root
# DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"

# WhatsApp (Cloud API + optional HTTP bridge for dev)
WHATSAPP_CLOUD_ENABLED=false
WHATSAPP_CLOUD_TOKEN=
WHATSAPP_CLOUD_PHONE_NUMBER_ID=
WHATSAPP_CLOUD_API_VERSION=v21.0
WHATSAPP_TEMPLATE_LANGUAGE=en_US
WHATSAPP_TEMPLATE_ORDER_PLACED=
WHATSAPP_TEMPLATE_PAYMENT_RECEIVED=
WHATSAPP_TEMPLATE_ORDER_PACKED=
WHATSAPP_TEMPLATE_ORDER_SHIPPED=
WHATSAPP_TEMPLATE_ORDER_DELIVERED=
WHATSAPP_TEMPLATE_ORDER_CANCELED=
WHATSAPP_BRIDGE_ENABLED=true
WHATSAPP_API_TOKEN=
WHATSAPP_API_URL=
WHATSAPP_FROM_NUMBER=
WHATSAPP_SEND_TRIES=5
WHATSAPP_SEND_BACKOFF=60
WHATSAPP_SEND_TIMEOUT=30
# WHATSAPP_QUEUE=default

# Bargaining assistant (deterministic pricing + optional AI polish)
BARGAIN_ENABLED=true
BARGAIN_SESSION_TTL_MINUTES=30
BARGAIN_LOCK_TTL_MINUTES=60
BARGAIN_MIN_STEP_PKR=100

# In-range nudge: bump stated offers slightly toward list when still policy-compliant.
BARGAIN_IN_RANGE_NUDGE_ENABLED=true
BARGAIN_IN_RANGE_NUDGE_MIN_STEP_PKR=100
BARGAIN_IN_RANGE_NUDGE_MAX_FRACTION=0.4
BARGAIN_AI_ENABLED=false
BARGAIN_AI_BASE_URL=https://api.openai.com/v1
# Or set OPENAI_API_KEY if you already use it app-wide.
BARGAIN_AI_API_KEY=
BARGAIN_AI_MODEL=gpt-4o-mini
# Requires active billing/credits at platform.openai.com — otherwise chat stays on draft templates (HTTP 429).
# Windows SSL issues: BARGAIN_AI_HTTP_VERIFY=false (dev only)
# php artisan bargain:test-polisher — verify key + quota from CLI

# Storefront SEO: set APP_URL to your public site URL (used for canonicals, OG URLs, sitemap, robots).
# GA4 / Meta / TikTok IDs are configured in Admin → Marketing (stored in database).

# Safepay (https://getsafepay.com) — primary online payment gateway.
# Get keys from Dashboard → Developers → API Keys. Webhook secret from Developers → Endpoints.
SAFEPAY_ENABLED=true
SAFEPAY_ENVIRONMENT=sandbox
SAFEPAY_API_KEY=
SAFEPAY_MERCHANT_API_KEY=
SAFEPAY_WEBHOOK_SECRET=
SAFEPAY_INTENT=CYBERSOURCE
SAFEPAY_CURRENCY=PKR
SAFEPAY_INCLUDE_FEES=false

# Legacy wallet gateways are disabled by default in favour of Safepay.
# Flip to true and configure credentials if you want to re-enable them.
EASYPAISA_ENABLED=false
JAZZCASH_ENABLED=false
