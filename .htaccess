<IfModule mod_rewrite.c>
    <IfModule mod_negotiation.c>
        Options -MultiViews -Indexes
    </IfModule>

    RewriteEngine On

    # Canonical origin: force https + non-www in a SINGLE redirect hop.
    # Scoped to the production host so local dev (*.test, localhost) is untouched.
    # http(s)://www → https://non-www and http://non-www → https://non-www each resolve
    # to the final URL in one 301 (target host is fixed), avoiding redirect chains.
    RewriteCond %{HTTP_HOST} ^(www\.)?tryinotech\.cloud$ [NC]
    RewriteCond %{HTTPS} off
    RewriteCond %{HTTP:X-Forwarded-Proto} !https
    RewriteRule ^ https://tryinotech.cloud%{REQUEST_URI} [R=301,L,NE]

    RewriteCond %{HTTP_HOST} ^www\.tryinotech\.cloud$ [NC]
    RewriteRule ^ https://tryinotech.cloud%{REQUEST_URI} [R=301,L,NE]

    # Block direct web access to Laravel internals (app lives in web root).
    # Do not block "storage" — /storage/* is the public disk URL (public/storage symlink).
    RewriteRule ^(app|bootstrap|config|database|resources|routes|tests|vendor)(/|$) - [F,L]

    # 301: remove /public and /public/index.php from the browser URL.
    RewriteCond %{THE_REQUEST} \s/+public/index\.php[\s?] [NC]
    RewriteRule ^ / [R=301,L]

    RewriteCond %{THE_REQUEST} \s/+public/([^\s?]*) [NC]
    RewriteRule ^ /%1 [R=301,L,NE]

    RewriteCond %{THE_REQUEST} \s/+public[\s?] [NC]
    RewriteRule ^ / [R=301,L]

    # Serve the site from /public/ internally (clean URLs, no /public in path).
    RewriteCond %{REQUEST_URI} !^/public/
    RewriteRule ^(.*)$ public/$1 [L]
</IfModule>

<IfModule mod_headers.c>
    # Tell browsers to always use https for a year (skips the http→https redirect on repeat visits).
    Header always set Strict-Transport-Security "max-age=31536000; includeSubDomains"
</IfModule>

<IfModule mod_brotli.c>
    AddOutputFilterByType BROTLI_COMPRESS text/html text/plain text/css text/javascript application/javascript application/json application/xml image/svg+xml
</IfModule>

<IfModule mod_deflate.c>
    AddOutputFilterByType DEFLATE text/html text/plain text/css text/javascript application/javascript application/json application/xml image/svg+xml
</IfModule>

# LiteSpeed full-page cache. The app emits X-LiteSpeed-Cache-Control per response
# (see App\Http\Middleware\LiteSpeedGuestCache); only guest storefront HTML is marked
# public, everything else is no-cache. Also enable "LiteSpeed Cache" in hPanel.
<IfModule LiteSpeed>
    CacheLookup on
</IfModule>
